# Variables de entorno para CIVYM

# Google Sheets (opcional)
# Necesario solo si quieres guardar envíos del formulario en Google Sheets
# 
# GOOGLE_SERVICE_ACCOUNT_KEY: JSON completo del Service Account (escapando newlines con \n)
# Ejemplo: {"type":"service_account","project_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n","client_email":"...","auth_uri":"...","token_uri":"..."}
#
# GOOGLE_SHEET_ID: ID de tu hoja de cálculo (visible en la URL)
# Ejemplo: 1a2b3c4d5e6f7g8h9i10j11k12l
#
# GOOGLE_SHEET_NAME: Nombre de la pestaña donde se guardarán los datos
# Ejemplo: Sheet1

# GOOGLE_SERVICE_ACCOUNT_KEY=""
# GOOGLE_SHEET_ID=""
# GOOGLE_SHEET_NAME="Sheet1"
